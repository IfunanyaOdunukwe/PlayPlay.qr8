# Copy this file to secrets.toml and fill in your credentials.
# Create an app in https://developer.spotify.com/dashboard
# Then open the app settings to copy the Client ID and reveal the Client Secret.
# Add this redirect URI in Spotify if you run the app on the default local port.
# If you run Streamlit on another port, use that exact app URL instead.

spotify_client_id = ""
spotify_client_secret = ""
spotify_redirect_uri = "http://127.0.0.1:8501"

# Required — for the Playlist Sculptor page
# Get a Groq API key from https://console.groq.com/keys
groq_api_key = ""
